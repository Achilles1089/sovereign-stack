<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow file sharing via Finder/iTunes for GGUF model transfer -->
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
    
    <!-- Allow local network access for serving the API -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>SovereignAI needs network access to serve the inference API to your local network.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_http._tcp</string>
    </array>
    
    <!-- Keep screen on while serving -->
    <key>UIIdleTimerDisabled</key>
    <true/>
    
    <!-- App display name -->
    <key>CFBundleDisplayName</key>
    <string>SovereignAI</string>
    
    <!-- Background modes: audio keeps app alive -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>
</dict>
</plist>
